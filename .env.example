# Copy to .env for local dev. Set as env vars in Render/Railway dashboard for production.

# Required in production
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string_at_least_48_chars

# SQLite file location
# Local:      leave blank (defaults to ./supportly.db)
# Production: point to persistent disk, e.g. /var/data/supportly.db
DB_PATH=

# Set to "production" on your hosting platform
NODE_ENV=development

# Port (hosting platforms set this automatically)
PORT=3000
